---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
}

const { title, date } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title}>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.0/dist/katex.min.css" integrity="sha384-Xi8rHCmBmhbuyyhbI88391ZKP2dmfnOl4rT9ZfRI7mLTdk1wblIUnrIq35nqwEvC" crossorigin="anonymous" slot="head" />

  <div class="container mx-auto max-w-screen-md px-4">
    <header class="py-4 mb-6 border-b border-gray-200 dark:border-gray-700">
      <nav class="flex gap-6 text-[1.125rem]">
        <a class="text-blue-500 hover:underline" href="/blog">Blog</a>
        <a class="text-blue-500 hover:underline" href="/">Homepage</a>
      </nav>
    </header>

    <article class="prose prose-lg dark:prose-invert max-w-none font-serif">
      <h1 class="font-serif">{title}</h1>
      <time class="text-gray-500 dark:text-gray-400 text-sm not-prose" datetime={date.toISOString()}>
        {formattedDate}
      </time>
      <slot />
    </article>
  </div>
</BaseLayout>
