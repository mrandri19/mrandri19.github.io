  description="Andrea Cognolato's personal website and portfolio, contains his personal projects, resume and contact information."
>
<div class="
            container
            mx-auto
            max-w-screen-lg
            px-4
            font-sans
            text-base
        ">
    <header>
        <h1 class="text-4xl font-bold text-center my-4 leading-[3.5rem]">
            Andrea Cognolato
        </h1>
        <nav class="mb-3">
