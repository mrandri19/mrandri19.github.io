---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found">
  <div class="container mx-auto max-w-screen-md px-4 py-16 text-center">
    <h1 class="text-6xl font-bold mb-4">404</h1>
    <p class="text-xl font-bold mb-2">Page not found :(</p>
    <p>The requested page could not be found.</p>
    <a href="/" class="text-blue-500 hover:underline mt-4 inline-block">Go home</a>
  </div>
</BaseLayout>
